<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TradingBrowser.Controls"
        Title="Trading Browser"
        Width="1400"
        Height="900"
        Background="#202124"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#202124" BorderBrush="#3C4043" BorderThickness="0,0,0,1">
            <Grid Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TabControl x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged"/>
                <controls:WindowControls Grid.Column="1"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="#292A2D" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="←" Width="36" Click="Back_Click"/>
                <Button Grid.Column="1" Content="→" Width="36" Click="Forward_Click"/>
                <Button Grid.Column="2" Content="⟳" Width="36" Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="✕" Width="36" Click="Stop_Click"/>
                <Button Grid.Column="4" Content="+" Width="36" Click="NewTabButton_Click"/>
                <TextBox x:Name="AddressBar" Grid.Column="5" Margin="8,0,0,0"
                         Background="#303134" Foreground="White"
                         BorderBrush="#5F6368"
                         KeyDown="AddressBar_KeyDown"/>
            </Grid>
        </Border>

        <Grid x:Name="BrowserHost"/>
    </DockPanel>
</Window>
