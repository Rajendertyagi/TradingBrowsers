<Window x:Class="TradingBrowser.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:controls="clr-namespace:TradingBrowser.Controls"
 Title="Trading Browser"
 Width="1400" Height="900"
 Background="#202124"
 WindowStyle="None"
 ResizeMode="CanResize"
 WindowStartupLocation="CenterScreen">
<DockPanel>
  <Border DockPanel.Dock="Top" Background="#202124" Height="38" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="8,4,0,0" Background="#1F1F1F"
                CornerRadius="10,10,0,0"
                BorderBrush="#3C4043" BorderThickness="1,1,1,0">
          <TextBlock Text="New Tab"
                     Foreground="#E8EAED"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0"/>
        </Border>

        <Button Grid.Column="1"
                Content="+"
                FontSize="18"
                FontWeight="Bold"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                Click="NewTabButton_Click"/>
      </Grid>

      <controls:WindowControls Grid.Column="1"/>
    </Grid>
  </Border>

  <Border DockPanel.Dock="Top" Background="#292A2D" Height="48" Padding="8">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Content="←" Width="32" Height="32" Margin="0,0,4,0" Click="Back_Click"/>
      <Button Grid.Column="1" Content="→" Width="32" Height="32" Margin="0,0,4,0" Click="Forward_Click"/>
      <Button Grid.Column="2" Content="⟳" Width="32" Height="32" Margin="0,0,4,0" Click="Refresh_Click"/>
      <Button Grid.Column="3" Content="⌂" Width="32" Height="32" Margin="0,0,8,0" Click="Home_Click"/>

      <Border Grid.Column="4" Background="#202124" CornerRadius="18" BorderBrush="#3C4043" BorderThickness="1">
        <TextBox x:Name="AddressBar"
                 Background="Transparent"
                 Foreground="#E8EAED"
                 BorderThickness="0"
                 Margin="14,0"
                 VerticalContentAlignment="Center"
                 KeyDown="AddressBar_KeyDown"/>
      </Border>
    </Grid>
  </Border>

  <Grid x:Name="BrowserHost"/>
</DockPanel>
</Window>