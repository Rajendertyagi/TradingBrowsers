<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TradingBrowser.Controls"
        Title="TradingView Browser"
        Width="1400"
        Height="900"
        MinWidth="900"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0B0F1A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Space Background -->
        <LinearGradientBrush x:Key="SpaceBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#05070F" Offset="0"/>
            <GradientStop Color="#0A1020" Offset="0.45"/>
            <GradientStop Color="#120B25" Offset="0.75"/>
            <GradientStop Color="#05070F" Offset="1"/>
        </LinearGradientBrush>

        <!-- Aurora Glow -->
        <RadialGradientBrush x:Key="AuroraBrush"
                             Center="0.35,0.18"
                             RadiusX="0.6"
                             RadiusY="0.45">
            <GradientStop Color="#55FF00FF" Offset="0"/>
            <GradientStop Color="#2200BFFF" Offset="0.35"/>
            <GradientStop Color="#00000000" Offset="1"/>
        </RadialGradientBrush>

        <!-- Theme Brushes -->
        <SolidColorBrush x:Key="TopBarBrush" Color="#111827"/>
        <SolidColorBrush x:Key="ToolbarBrush" Color="#161B26"/>
        <SolidColorBrush x:Key="OmniboxBrush" Color="#0D111C"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EAF2FF"/>

        <!-- Toolbar Button Style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#22314D"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#2D4B73"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource SpaceBackground}">

        <!-- Space Glow Overlay -->
        <Rectangle Fill="{StaticResource AuroraBrush}"
                   IsHitTestVisible="False"/>

        <DockPanel LastChildFill="True">

            <!-- ================= TITLE BAR ================= -->
            <Border DockPanel.Dock="Top"
                    Height="38"
                    Background="{StaticResource TopBarBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tabs -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <!-- Active Tab -->
                        <Border Grid.Column="0"
                                Margin="8,4,0,0"
                                Background="#0F172A"
                                CornerRadius="12,12,0,0"
                                BorderBrush="#334155"
                                BorderThickness="1,1,1,0">

                            <StackPanel Orientation="Horizontal"
                                        Margin="10,0"
                                        VerticalAlignment="Center">

                                <!-- Favicon -->
                                <TextBlock Text="📈"
                                           FontSize="12"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>

                                <!-- Tab Title -->
                                <TextBlock Text="TradingView"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- New Tab Button -->
                        <Button Grid.Column="1"
                                Content="+"
                                FontSize="18"
                                FontWeight="Bold"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="NewTabButton_Click"/>
                    </Grid>

                    <!-- Custom Window Controls -->
                    <controls:WindowControls Grid.Column="1"/>
                </Grid>
            </Border>

            <!-- ================= TOOLBAR ================= -->
            <Border DockPanel.Dock="Top"
                    Height="48"
                    Background="{StaticResource ToolbarBrush}"
                    BorderBrush="#1F2937"
                    BorderThickness="0,0,0,1"
                    Padding="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Navigation -->
                    <Button Grid.Column="0"
                            Content="←"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="Back_Click"/>

                    <Button Grid.Column="1"
                            Content="→"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="Forward_Click"/>

                    <Button Grid.Column="2"
                            Content="⟳"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="Refresh_Click"/>

                    <Button Grid.Column="3"
                            Content="⌂"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="Home_Click"/>

                    <!-- Address Bar -->
                    <Border Grid.Column="4"
                            Margin="8,0"
                            Background="{StaticResource OmniboxBrush}"
                            CornerRadius="20"
                            BorderBrush="#334155"
                            BorderThickness="1">

                        <TextBox x:Name="AddressBar"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 FontSize="14"
                                 Margin="16,0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="White"
                                 KeyDown="AddressBar_KeyDown"/>
                    </Border>

                    <!-- Downloads Button -->
                    <Button Grid.Column="5"
                            Content="↓"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Downloads (Ctrl+J)"/>
                </Grid>
            </Border>

            <!-- ================= BROWSER HOST ================= -->
            <Grid x:Name="BrowserHost"
                  Background="Transparent"/>
        </DockPanel>
    </Grid>
</Window>
