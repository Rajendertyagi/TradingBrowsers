<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Trading Browser"
        Width="1400"
        Height="900"
        Background="#202124"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <!-- Tab Strip (Chrome-like) -->
        <Border DockPanel.Dock="Top"
                Background="#202124"
                BorderBrush="#3C4043"
                BorderThickness="0,0,0,1">

            <Grid Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TabControl x:Name="Tabs"
                            Grid.Column="0"
                            Background="#202124"
                            BorderThickness="0"
                            SelectionChanged="Tabs_SelectionChanged">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#2D2F31"/>
                            <Setter Property="BorderBrush" Value="#3C4043"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Margin" Value="2,4,0,4"/>
                        </Style>
                    </TabControl.Resources>
                </TabControl>

                <Button Grid.Column="1"
                        Content="+"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#202124"
                        Foreground="White"
                        BorderBrush="#202124"
                        Click="NewTabButton_Click"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Navigation Bar -->
        <Border DockPanel.Dock="Top"
                Background="#2D2F31"
                Padding="8"
                BorderBrush="#3C4043"
                BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="←" Width="36" Margin="2" Click="Back_Click"/>
                <Button Grid.Column="1" Content="→" Width="36" Margin="2" Click="Forward_Click"/>
                <Button Grid.Column="2" Content="⟳" Width="36" Margin="2" Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="✕" Width="36" Margin="2" Click="Stop_Click"/>
                <Button Grid.Column="4" Content="⌂" Width="36" Margin="2" Click="Home_Click"/>

                <TextBox x:Name="AddressBar"
                         Grid.Column="5"
                         Margin="8,0,0,0"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Background="#3C4043"
                         Foreground="White"
                         BorderBrush="#5F6368"
                         KeyDown="AddressBar_KeyDown"/>
            </Grid>
        </Border>

        <!-- Browser Area -->
        <Grid x:Name="BrowserHost" Background="#202124"/>

    </DockPanel>
</Window>
