<Window x:Class="TradingBrowser.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Trading Browser" Width="1400" Height="900">
  <DockPanel>
    <ToolBar DockPanel.Dock="Top">
      <Button Name="BackButton" Content="←" Width="32"/>
      <Button Name="ForwardButton" Content="→" Width="32"/>
      <Button Name="RefreshButton" Content="⟳" Width="32"/>
      <TextBox Name="AddressBar" Width="700" Margin="8,0"/>
      <Button Name="GoButton" Content="Go"/>
    </ToolBar>
    <TabControl Name="Tabs"/>
  </DockPanel>
</Window>