<!-- Replace your entire MainWindow.xaml with this.
     This adds a real TabControl named Tabs.
     Your existing MainWindow.xaml.cs and Services/TabManager.cs will then be able to create real tabs. -->

<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TradingBrowser.Controls"
        Title="TTBrowserGPT"
        Width="1400"
        Height="900"
        MinWidth="900"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1115"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="TopBarBrush" Color="#1E1F22"/>
        <SolidColorBrush x:Key="ToolbarBrush" Color="#202124"/>
        <SolidColorBrush x:Key="OmniboxBrush" Color="#2A2B2E"/>
        <SolidColorBrush x:Key="TextBrush" Color="White"/>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel Background="#0F1115">

        <!-- TITLE BAR -->
        <Border DockPanel.Dock="Top"
                Height="38"
                Background="{StaticResource TopBarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- REAL TAB STRIP -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <!-- Actual TabControl -->
                    <TabControl x:Name="Tabs"
                                Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="4,4,0,0"/>

                    <!-- New Tab Button -->
                    <Button Grid.Column="1"
                            Content="+"
                            FontSize="18"
                            FontWeight="Bold"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="NewTabButton_Click"/>
                </Grid>

                <!-- Window Controls -->
                <controls:WindowControls Grid.Column="1"/>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border DockPanel.Dock="Top"
                Height="48"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="#303134"
                BorderThickness="0,0,0,1"
                Padding="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="←"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="Back_Click"/>

                <Button Grid.Column="1"
                        Content="→"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="Forward_Click"/>

                <Button Grid.Column="2"
                        Content="⟳"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="Refresh_Click"/>

                <Button Grid.Column="3"
                        Content="⌂"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="Home_Click"/>

                <Border Grid.Column="4"
                        Margin="8,0"
                        Background="{StaticResource OmniboxBrush}"
                        CornerRadius="20"
                        BorderBrush="#3C4043"
                        BorderThickness="1">

                    <TextBox x:Name="AddressBar"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             Margin="16,0"
                             VerticalContentAlignment="Center"
                             CaretBrush="White"
                             KeyDown="AddressBar_KeyDown"/>
                </Border>

                <Button Grid.Column="5"
                        Content="↓"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Downloads"/>
            </Grid>
        </Border>

        <!-- Browser host used by TabManager -->
        <Grid x:Name="BrowserHost"
              Background="#0F1115"/>
    </DockPanel>
</Window>
