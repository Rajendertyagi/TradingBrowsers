<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Trading Browser"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Top Toolbar -->
        <ToolBar DockPanel.Dock="Top">

            <Button Content="←"
                    Width="35"
                    Margin="2"
                    Click="Back_Click"/>

            <Button Content="→"
                    Width="35"
                    Margin="2"
                    Click="Forward_Click"/>

            <Button Content="⟳"
                    Width="35"
                    Margin="2"
                    Click="Refresh_Click"/>

            <TextBox x:Name="AddressBar"
                     Width="900"
                     Margin="8,0"
                     VerticalContentAlignment="Center"
                     KeyDown="AddressBar_KeyDown"/>

            <Button Content="Go"
                    Width="60"
                    Margin="2"
                    Click="Go_Click"/>

        </ToolBar>

        <!-- Web Browser Control -->
        <wv2:WebView2 x:Name="Browser"/>

    </DockPanel>
</Window>
