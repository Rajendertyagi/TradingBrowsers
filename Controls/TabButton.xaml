<UserControl x:Class="TradingBrowser.Controls.TabButton"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Height="34" Width="220">
    <Border x:Name="RootBorder" Background="#2B2B2B" CornerRadius="10,10,0,0"
            BorderBrush="#3C4043" BorderThickness="1,1,1,0" Padding="10,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText" VerticalAlignment="Center"
                       Foreground="#E8EAED" Text="New Tab"/>
            <Button x:Name="CloseButton" Grid.Column="1" Content="×"
                    Background="Transparent" Foreground="#E8EAED"
                    BorderThickness="0"/>
        </Grid>
    </Border>
</UserControl>
